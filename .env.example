# StudyVerse environment variables
# Copy this file to `.env.local` and fill in the values you have.
# Every variable is OPTIONAL — the app runs fully in local-only mode when they
# are absent (Study Rooms fall back to a same-browser BroadcastChannel sync,
# and the AI coach shows a friendly "not configured" message).

# --- AI Study Coach (server-only, never exposed to the browser) ---
# Anthropic API key. Enables the in-dashboard AI coach + search assistant.
ANTHROPIC_API_KEY=

# --- Supabase (public — safe to expose; used by the browser client) ---
# Enables cross-device Study Rooms: room storage, live participants,
# realtime chat and a shared Pomodoro timer via Supabase Realtime.
# Find these under: Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
